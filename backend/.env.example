# DocSuri backend (app-shell) — configuration surface. Copy to .env for local use.
# All values have boot-safe defaults; the shell starts with none of these set.

# Environment: local | test | dev | production
ENV=local

# Database (accounts/U3). Default is SQLite (no server). Set to Postgres in real envs:
#   DATABASE_URL=postgresql+psycopg://docsuri:docsuri@localhost:5432/docsuri
DATABASE_URL=sqlite:///./docsuri-dev.db

# CORS allow-list (comma-separated). MUST be explicit origins — wildcard is invalid with
# credentialed cookie sessions (SEC-12). Defaults to the SSR frontend dev origins.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# accounts (U3) module env — consumed by backend.modules.accounts when mounted:
#   RECAPTCHA_SECRET_KEY=...      # reCAPTCHA v3 server secret (empty = dev)
#   SES_MOCK=true                 # print verification links to console instead of sending mail
# Redis (session store) currently defaults to localhost:6379 inside the accounts module.

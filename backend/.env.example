# DocSuri backend 환경 변수 — NFR-SEC-03: 키는 환경 변수로만, 저장소에 평문 금지.
# 실제 값은 .env(비추적) 또는 Lambda 환경 변수/SSM에 둔다.

# 어댑터 모드: mock(자격 증명 불필요, U0 §6 시연용) | aws(ADR §12 실구현)
DOCSURI_ADAPTER_MODE=mock

# --- aws 모드에서만 필요 (ADR-D9: 서울 리전, 2026-06-11 ADR-D3 재검토) ---
AWS_REGION=ap-northeast-2
# Bedrock 모델 ID — 콘솔에서 최종 확인 (ADR §14 검증 항목)
DOCSURI_BEDROCK_LLM_MODEL_ID=global.anthropic.claude-haiku-4-5-20251001-v1:0
DOCSURI_BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
# Bedrock Knowledge Base (ADR-D2: S3 Vectors 스토어)
DOCSURI_KB_ID=
# S3 Vectors 직접 조회 (search 시그니처용 — ADR-D2 결과 3)
DOCSURI_S3V_BUCKET=docsuri-vectors
DOCSURI_S3V_INDEX=papers
# DynamoDB 테이블 (ADR §12: 캐시·용어집·비용 누적)
DOCSURI_DDB_CACHE_TABLE=docsuri-cache
DOCSURI_DDB_GLOSSARY_TABLE=docsuri-glossary
DOCSURI_DDB_COST_TABLE=docsuri-cost

# Semantic Scholar API 키 (선택 — 레이트 리밋 완화, 리뷰 M2)
DOCSURI_SS_API_KEY=

# CostGuard 상한 (NFR-COST-01) — 하드 거부 정책
DOCSURI_COST_MONTHLY_CAP_USD=50

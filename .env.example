# PostgreSQL connection string. Leave empty to run the built-in demo dataset.
DATABASE_URL=

# Used when DATABASE_URL is empty or PostgreSQL cannot be reached.
# Drop .json, .md, .txt, or .pdf papers here to use the filesystem as a local store.
LOCAL_PAPER_DIR=local_papers

# Optional LLM provider. Without ANTHROPIC_API_KEY the app uses a deterministic mock
# provider so the UI and DB integration can be demoed locally.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_VERIFIER_MODEL=claude-haiku-4-5-20251001

# Default schema assumptions. Override these when your ingestion schema differs.
PAPER_TABLE=papers
PAPER_CHUNK_TABLE=paper_chunks
PAPER_ID_COLUMN=id
PAPER_CHUNK_PAPER_ID_COLUMN=paper_id

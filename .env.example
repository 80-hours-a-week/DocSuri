# Required PostgreSQL / PGVector connection string.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/docsuri

# AWS Bedrock Runtime settings. Credentials are resolved by boto3:
# environment variables, AWS_PROFILE, shared credentials, SSO, ECS/EC2 role, etc.
AWS_REGION=ap-northeast-2
# AWS_PROFILE=default

# Required Bedrock model IDs.
ANTHROPIC_MODEL=anthropic.claude-opus-4-6-v1
ANTHROPIC_VERIFIER_MODEL=anthropic.claude-haiku-4-5-20251001-v1:0
EMBEDDING_MODEL=twelvelabs.marengo-embed-3-0-v1:0
RETRIEVAL_TOP_K=8

# Default schema assumptions. Override these when your ingestion schema differs.
PAPER_TABLE=papers
PAPER_CHUNK_TABLE=paper_chunks
PAPER_ID_COLUMN=id
PAPER_CHUNK_PAPER_ID_COLUMN=paper_id
PAPER_CHUNK_EMBEDDING_COLUMN=embedding

# DocSuri — frontend .env example. Copy to `.env.local`.

# Backend (FastAPI). Rewritten via next.config.mjs (/api/backend/* -> $BACKEND_URL/api/*).
BACKEND_URL=http://localhost:8000

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# OAuth providers (ORCID arrives with #11 / #04 sprints)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LLM (Vercel AI SDK)
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5

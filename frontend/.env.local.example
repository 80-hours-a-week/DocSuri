# Set DOCSURI_GATEWAY_URL to connect to the real backend (U6 gateway).
# When unset, the frontend falls back to MockTransport (mock fixtures, no backend needed).
#
# Local development (backend running on localhost:8000):
#   DOCSURI_GATEWAY_URL=http://localhost:8000
#
# Production (ECS ALB endpoint):
#   DOCSURI_GATEWAY_URL=https://api.docsuri.dev
#
# This is a SERVER-ONLY variable (no NEXT_PUBLIC_ prefix) — it never reaches the browser
# bundle (SEC-3/12). The session cookie is forwarded server-side only (httpOnly, SEC-12).
DOCSURI_GATEWAY_URL=http://localhost:8000

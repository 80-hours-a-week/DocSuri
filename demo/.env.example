# Semantic Paper Workbench — Sprint 1 Demo environment.
# Copy to `.env` (gitignored) and fill in. ALL VARS ARE OPTIONAL.
#
# Unset -> "mock" mode: deterministic offline LLM + abstract-only ingest.
# Set ANTHROPIC_API_KEY -> "live" mode: real Claude calls (Sonnet/Haiku).
# Set GROBID_URL        -> real PDF parsing via GROBID; otherwise abstract-only.

# Anthropic API key. Live Claude calls when set; mock LLM otherwise (AGENTS.md §4.1).
ANTHROPIC_API_KEY=

# GROBID HTTP base URL (e.g. http://localhost:8070). Abstract-only fallback when unset (AGENTS.md §4.2).
GROBID_URL=

# Bind address for uvicorn. Use 0.0.0.0 to expose on LAN, 127.0.0.1 for local-only.
HOST=0.0.0.0

# HTTP port for the demo server. Smoke + frontend assume 8000.
PORT=8000

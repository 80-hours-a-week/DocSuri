# DocSuri — backend .env example (AGENTS.md §5 architecture).
# Copy to `.env` (gitignored) and fill in. NEVER commit secrets.
#
# Modes:
#   ANTHROPIC_API_KEY unset → "mock" LLM (deterministic offline).
#   GROBID_URL unset        → abstract-only ingest fallback (§4.2).

# ---- Server ----
HOST=0.0.0.0
PORT=8000

# ---- LLM ----
# Phase 0: direct Anthropic SDK. Bedrock switch is bundled with EKS adoption.
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5
LLM_MODE=live           # live | mock

# ---- Embeddings ----
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# ---- Paper ingest ----
GROBID_URL=

# ---- Storage (Phase 0 = local Docker Compose) ----
DATABASE_URL=postgresql+psycopg://docsuri:docsuri@localhost:5432/docsuri
REDIS_URL=redis://localhost:6379/0

# ---- Background (Celery + SQS via LocalStack) ----
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
# Domain event topic (single SNS topic per §5.3).
EVENT_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:docsuri-domain-events

# ---- Observability (OTLP; backend decided later) ----
OTEL_SERVICE_NAME=docsuri-api
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_RESOURCE_ATTRIBUTES=service.namespace=docsuri,deployment.environment=dev
LOG_LEVEL=INFO
LOG_FORMAT=json         # json | console

# ---- Inbound rate limit (SlowAPI; §4.5) ----
# See crosscutting/ratelimit/inbound.py — key strategy.
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_STORAGE_URI=redis://localhost:6379/3

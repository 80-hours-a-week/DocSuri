# Semantic Paper Workbench — Sprint 1 Demo environment.
# Copy to `.env` (gitignored) and fill in. ALL VARS ARE OPTIONAL unless noted.
#
# Unset -> "mock" mode: deterministic offline LLM + abstract-only ingest.
# Set ANTHROPIC_API_KEY -> "live" mode: real Claude calls (Sonnet/Haiku).
# Set GROBID_URL        -> real PDF parsing via GROBID; otherwise abstract-only.

# ── LLM (우선순위: Bedrock → Anthropic 직접 → MockLLM) ──────────────────────

# [권장] AWS Bedrock — Claude Haiku/Sonnet 사용 시
# AWS_BEDROCK_REGION 설정 시 Bedrock 어댑터가 활성화됨.
# AWS 자격증명은 아래 키 또는 IAM 인스턴스 역할로 자동 해석됨.
AWS_BEDROCK_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=   # 임시 자격증명(STS AssumeRole) 사용 시만 필요

# 모델 ID 오버라이드 (기본값으로 충분하면 생략 가능)
# BEDROCK_HAIKU_MODEL=anthropic.claude-3-5-haiku-20241022-v1:0
# BEDROCK_SONNET_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# [대안] Anthropic 직접 API — AWS_BEDROCK_REGION 미설정 시에만 활성화됨.
ANTHROPIC_API_KEY=

# ── Embeddings ────────────────────────────────────────────────────────────────

# OpenAI API key. Required for pgvector semantic search (text-embedding-3-large, 3072-dim).
# Used by: infra/embedding/openai.py, search pipeline step 4.
# Unset -> pgvector search step silently skipped; adapter fan-out still works.
OPENAI_API_KEY=

# ── Storage ───────────────────────────────────────────────────────────────────

# PostgreSQL connection string with pgvector extension installed.
# Required for semantic similarity search and paper embedding storage.
# Example: postgresql://user:password@localhost:5432/docsuri
# Unset -> pgvector steps silently skipped.
DATABASE_URL=

# Redis connection URL.
# Used by: search result cache (TTL 1h) and query expansion cache (TTL 6h).
# Example: redis://localhost:6379/0
# Unset -> caches silently disabled (no-op); all requests fan out to adapters.
REDIS_URL=

# ── PDF parsing ───────────────────────────────────────────────────────────────

# GROBID HTTP base URL (e.g. http://localhost:8070). Abstract-only fallback when unset (AGENTS.md §4.2).
GROBID_URL=

# ── Server ────────────────────────────────────────────────────────────────────

# Bind address for uvicorn. Use 0.0.0.0 to expose on LAN, 127.0.0.1 for local-only.
HOST=0.0.0.0

# HTTP port for the demo server. Smoke + frontend assume 8000.
PORT=8000
